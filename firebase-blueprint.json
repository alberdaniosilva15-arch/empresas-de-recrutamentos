{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile (Recruiter or Candidate)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["recruiter", "candidate"] },
        "companyId": { "type": "string", "description": "ID of the company (only for recruiters)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Company": {
      "title": "Company",
      "description": "Company profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting for logistics/supply chain",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["Full-time", "Part-time", "Contract"] },
        "status": { "type": "string", "enum": ["open", "closed", "expired"] },
        "companyId": { "type": "string" },
        "requiredSkills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "location", "type", "status", "companyId"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "Candidate profile and CV analysis",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "cvText": { "type": "string" },
        "cvUrl": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experienceKeywords": { "type": "array", "items": { "type": "string" } },
        "score": { "type": "integer" },
        "scoreBreakdown": {
          "type": "object",
          "properties": {
            "skills": { "type": "integer" },
            "experience": { "type": "integer" },
            "education": { "type": "integer" }
          }
        },
        "classification": { "type": "string", "enum": ["baixo", "médio", "alto"] },
        "status": { "type": "string", "enum": ["Novo", "Triagem", "Entrevista", "Teste Técnico", "Proposta", "Contratado", "Rejeitado"] },
        "jobId": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "status", "companyId"]
    },
    "Application": {
      "title": "Application",
      "description": "Application of a candidate to a job",
      "type": "object",
      "properties": {
        "candidateId": { "type": "string" },
        "jobId": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string", "enum": ["Novo", "Triagem", "Entrevista", "Teste Técnico", "Proposta", "Contratado", "Rejeitado"] },
        "compatibilityScore": { "type": "integer" },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["candidateId", "jobId", "companyId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Company profiles"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings"
    },
    "/candidates/{candidateId}": {
      "schema": "Candidate",
      "description": "Candidate profiles"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications"
    }
  }
}
